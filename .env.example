# Database Connection Configuration
# Copy this file to .env and fill in your actual database credentials.
# The .env file is used by db.php to connect to the database.

# Hostname or IP of the database server
DB_HOST=your-host-name

# Port number for database connection (default MySQL port is 3306)
DB_PORT=3306

# Username for database authentication
DB_USER=your-username

# Password for database authentication
# IMPORTANT: Never commit .env to git. Always use .gitignore to exclude it.
DB_PASS=your-password

# Name of the database to use
DB_NAME=your-database-name
